# Database (same names as the Next.js app)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=username
DB_PASSWORD=password
# Use either DB_DATABASE or DB_NAME
DB_DATABASE=your_database_name

# CORS: origin of the Next.js dev server
FRONTEND_ORIGIN=http://localhost:3000

# Optional: outgoing email (omit to skip sending mail)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# MAIL_FROM=
# MAIL_FROM_NAME=Showtime Bookings
